#!/usr/bin/env sh
set -eu

die() {
    printf '%s\n' "pre-commit hook: $*" >&2
    exit 1
}

info() {
    printf '%s\n' "pre-commit hook: $*"
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root" || die "failed to enter repository root"

# Prefer the project venv (survives re-clones via repo-relative path). Use `-f` + a
# quick `python -m pre_commit` probe instead of `-x` alone: some environments mark
# the venv interpreter in ways that make `-x` unreliable, and falling back to `python3`
# would pick a system interpreter without pre-commit (e.g. Homebrew Python 3.14).
select_pre_commit_python() {
    _repo="$1"
    _rel="@PRE_COMMIT_VENV_PYTHON_REL@"
    _abs="@PRE_COMMIT_VENV_PYTHON_FOR_HOOK@"

    if [ -n "$_rel" ]; then
        _c="${_repo}/${_rel}"
        if [ -f "$_c" ] && "$_c" -m pre_commit --version >/dev/null 2>&1; then
            printf '%s\n' "$_c"
            return 0
        fi
    fi
    if [ -n "$_abs" ]; then
        _c="$_abs"
        if [ -f "$_c" ] && "$_c" -m pre_commit --version >/dev/null 2>&1; then
            printf '%s\n' "$_c"
            return 0
        fi
    fi
    for _c in python3 python; do
        if command -v "$_c" >/dev/null 2>&1 \
            && "$_c" -m pre_commit --version >/dev/null 2>&1; then
            command -v "$_c"
            return 0
        fi
    done
    return 1
}

PRE_COMMIT_PYTHON="$(select_pre_commit_python "$repo_root")" \
    || die "pre-commit not found in the project venv; re-run mb_pre_commit_setup (CMake or python/mb-pre-commit-setup.py)"

[ -f ".pre-commit-config.yaml" ] || exit 0

staged_file_list="$(mktemp "${TMPDIR:-/tmp}/pre-commit-staged-files.XXXXXX")"
cleanup() {
    rm -f "$staged_file_list"
}
trap cleanup EXIT HUP INT TERM

git diff --cached --name-only --diff-filter=ACMR -z |
while IFS= read -r -d '' path; do
    if [ -f "$path" ]; then
        printf '%s\0' "$path" >> "$staged_file_list"
    fi
done

[ -s "$staged_file_list" ] || exit 0

run_pre_commit_on_staged_files() {
    xargs -0 "$PRE_COMMIT_PYTHON" -m pre_commit run --hook-stage pre-commit --files < "$staged_file_list"
}

restage_existing_files() {
    restage_list="$(mktemp "${TMPDIR:-/tmp}/pre-commit-restage.XXXXXX")" || exit 1
    trap 'rm -f "$staged_file_list" "$restage_list"' EXIT HUP INT TERM

    xargs -0 -I '{}' sh -c '
        if [ -f "$1" ]; then
            printf "%s\0" "$1"
        fi
    ' sh '{}' < "$staged_file_list" > "$restage_list"

    if [ -s "$restage_list" ]; then
        xargs -0 git add -- < "$restage_list" || die "failed to re-stage files modified by pre-commit"
    fi

    rm -f "$restage_list"
    trap cleanup EXIT HUP INT TERM
}

if run_pre_commit_on_staged_files; then
    exit 0
fi

restage_existing_files

if run_pre_commit_on_staged_files; then
    info "auto-fixed staged files with pre-commit, updated the index, and continuing commit"
    exit 0
fi

die "pre-commit checks failed"
